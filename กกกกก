local function ApplyInvisibility(state)
    local character = Player.Character
    if not character then return end
    
    local transparency = state and 1 or 0
    
    for _, part in pairs(character:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            part.Transparency = transparency
        elseif part:IsA("Decal") then
            part.Transparency = transparency
        end
    end
end

InvisButton.MouseButton1Click:Connect(function()
    isInvisible = not isInvisible
    if isInvisible then
        InvisButton.Text = "Invisible: ON"
        InvisButton.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        ApplyInvisibility(true)
    else
        InvisButton.Text = "Invisible: OFF"
        InvisButton.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
        ApplyInvisibility(false)
    end
end)

Player.CharacterAdded:Connect(function(char)
    task.wait(0.5)
    if isInvisible then ApplyInvisibility(true) end
end)

local dragging = false
local isTweening = false

local function ApplySpeed()
    local targetSpeed = tonumber(ValueLabel.Text) or defaultSpeed
    if Player.Character and Player.Character:FindFirstChild("Humanoid") then
        Player.Character.Humanoid.WalkSpeed = targetSpeed
    end
end

local function updateSlider(input)
    local pos = math.clamp((input.Position.X - SliderBackground.AbsolutePosition.X) / SliderBackground.AbsoluteSize.X, 0, 1)
    SliderBar.Size = UDim2.new(pos, 0, 1, 0)
    SliderButton.Position = UDim2.new(pos, -8, 0.5, -8)
    local finalSpeed = math.floor(minSpeed + (pos * (maxSpeed - minSpeed)))
    ValueLabel.Text = tostring(finalSpeed)
    ApplySpeed()
end

SliderButton.MouseButton1Down:Connect(function() dragging = true end)
UIS.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        updateSlider(input)
    end
end)
UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
end)

TpButton.MouseButton1Click:Connect(function()
    if isTweening then return end
    local char = Player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    isTweening = true
    TpButton.Text = "TELEPORTING..."
    TpButton.BackgroundColor3 = Color3.fromRGB(100, 50, 0)

    local targetCFrame = CFrame.new(-519.878357, 19.4365158, -520.073486, -0.848503113, -2.54526036e-08, -0.529190421, -8.01384648e-16, 1, -4.80972489e-08, 0.529190421, -4.08106615e-08, -0.848503113)
    local duration = 1

    local bV = Instance.new("BodyVelocity")
    bV.Velocity = Vector3.new(0, 0, 0)
    bV.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    bV.Parent = root

    local bG = Instance.new("BodyGyro")
    bG.P = 9e4
    bG.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    bG.CFrame = root.CFrame
    bG.Parent = root

    local noclipLoop = RunService.Stepped:Connect(function()
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end)

    local tween = TweenService:Create(root, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
    tween:Play()

    tween.Completed:Connect(function()
        noclipLoop:Disconnect()
        bV:Destroy()
        bG:Destroy()
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
            end
        end
        isTweening = false
        TpButton.Text = "TP to WWW"
        TpButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        ApplySpeed()
    end)
end)

local function SetupSpeedLock(char)
    local hum = char:WaitForChild("Humanoid")
    hum:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
        local desired = tonumber(ValueLabel.Text) or defaultSpeed
        if hum.WalkSpeed ~= desired and not isTweening then
            hum.WalkSpeed = desired
        end
    end)
    ApplySpeed()
end

Player.CharacterAdded:Connect(SetupSpeedLock)
if Player.Character then SetupSpeedLock(Player.Character) end

